# ─── Demo simulation ──────────────────────────────────────────────────────────
def demo_tick():
    global _dt
    _dt += 0.025
    spd  = max(0, 45 + 35 * math.sin(_dt * 0.28))
    mph  = spd * 0.621371
    bpct = int(65 + 15 * math.sin(_dt * 0.04))
    bv   = 22.5 + 1.8 * math.sin(_dt * 0.04)
    ba   = (spd * 0.45) + abs(3.0 * math.sin(_dt * 0.19))

    ST["spd"]    = spd
    ST["spd_mph"]= mph
    ST["df"]     = max(8, 160 + 130 * math.sin(_dt * 0.62))
    ST["db"]     = max(8, 190 + 100 * math.sin(_dt * 0.51 + 2))
    ST["bpct"]   = bpct
    ST["bv"]     = round(bv, 2)
    ST["ba"]     = round(ba, 2)
    ST["bmw"]    = bv * ba * 1000
    ST["brange"] = round(4.5 + 2 * math.sin(_dt * 0.03), 1)
    ST["gl"]     = round(0.65 * math.sin(_dt * 1.1), 2)
    ST["gn"]     = round(0.40 * math.sin(_dt * 0.7 + 1), 2)
    ST["tb"]     = round(32 + 5 * math.sin(_dt * 0.05), 1)
    ST["tm"]     = round(45 + 8 * math.sin(_dt * 0.04 + 0.5), 1)
    ST["hot"]    = ST["tb"] > 60 or ST["tm"] > 60
    ST["lobatt"] = bpct < 20

    limit = 5.0 if ST["pit_lane"] else ST["speed_limit"]
    was_warning = ST["speedwarn"]
    ST["speedwarn"] = ST["running"] and mph > limit

    # Track how long we spend over the limit
    if ST["running"]:
        if ST["speedwarn"]:
            if not was_warning:
                ST["speed_warn_count"] += 1
                ST["speed_warn_last_t"] = time.time()
            ST["speed_warn_total_secs"] += 0.025
        if spd > ST["max_spd"]:
            ST["max_spd"] = spd
        ST["trip_miles"] += mph * (0.025 / 3600.0)
        ST["total_wh"]   += (ST["bmw"] / 1000.0) * (0.025 / 3600.0)

        # Rolling average speed
        ST["spd_sum"]     += mph
        ST["spd_samples"] += 1
        ST["avg_spd"]      = ST["spd_sum"] / ST["spd_samples"]

        # IVD Data Logger (CSV)
        now_t = time.time()
        if now_t - ST["last_log_t"] >= 1.0:
            ST["last_log_t"] = now_t
            if not ST["log_file"]:
                ST["log_file"] = os.path.join(
                    LOG_DIR, f"ivd_session_{int(now_t)}.csv")
                with open(ST["log_file"], "w") as f:
                    f.write("Time,Speed_MPH,Voltage_V,Current_A,"
                            "Power_W,Batt_Temp_C,Motor_Temp_C,"
                            "Total_Wh,Trip_Miles\n")
            with open(ST["log_file"], "a") as f:
                f.write(
                    f"{datetime.now().strftime('%H:%M:%S')},"
                    f"{mph:.1f},{bv:.2f},{ba:.2f},"
                    f"{ST['bmw']/1000:.2f},{ST['tb']:.1f},{ST['tm']:.1f},"
                    f"{ST['total_wh']:.2f},{ST['trip_miles']:.3f}\n")

    if ST["lap_on"]:
        ST["lap_cur"] = time.time() - ST["lap_t0"]

    ST["pw_hist"].append(ST["bmw"] / 1000.0)
    ST["spd_hist"].append(spd)

    if ST["gl_max"] < abs(ST["gl"]): ST["gl_max"] = abs(ST["gl"])
    if ST["gn_max"] < abs(ST["gn"]): ST["gn_max"] = abs(ST["gn"])

    if ST["running"]:
        ST["g_hist"].append((ST["gl"], ST["gn"]))
        if abs(ST["gl"]) > abs(ST["gl_peak"]): ST["gl_peak"] = ST["gl"]
        if abs(ST["gn"]) > abs(ST["gn_peak"]): ST["gn_peak"] = ST["gn"]

# ─── Session helpers ──────────────────────────────────────────────────────────
def toggle_start():
    ST["running"] = not ST["running"]
    if ST["running"]:
        ST["session_t0"] = time.time()
        ST["session_start_str"] = datetime.now().strftime("%Y-%m-%d  %H:%M:%S")
        ST["confirm_msg"] = "SESSION STARTED"
    else:
        ST["confirm_msg"] = "SESSION PAUSED"
    ST["msg_t"] = time.time()

def toggle_lap():
    if not ST["running"]: return
    now = time.time()
    if not ST["lap_on"]:
        ST["lap_on"] = True
        ST["lap_t0"] = now
        ST["lap_n"]  += 1
    else:
        e = now - ST["lap_t0"]
        ST["laps"].append(e)
        if ST["lap_best"] is None or e < ST["lap_best"]:
            ST["lap_best"] = e
        ST["lap_t0"]  = now
        ST["lap_cur"] = e

def do_reset():
    ST["running"] = False
    ST["session_t0"] = None
    ST["session_start_str"] = ""
    ST["trip_miles"] = 0.0
    ST["max_spd"]    = 0.0
    ST["avg_spd"]    = 0.0
    ST["spd_sum"]    = 0.0
    ST["spd_samples"]= 0
    ST["lap_n"]  = 0
    ST["lap_on"] = False
    ST["lap_cur"] = 0.0
    ST["lap_best"]= None
    ST["laps"].clear()
    ST["pw_hist"].clear()
    ST["spd_hist"].clear()
    ST["reset_armed"] = False
    ST["gl_max"] = 0.0; ST["gn_max"] = 0.0
    ST["total_wh"]  = 0.0
    ST["log_file"]  = None
    ST["g_hist"].clear()
    ST["gl_peak"] = 0.0; ST["gn_peak"] = 0.0
    ST["speed_warn_count"] = 0
    ST["speed_warn_total_secs"] = 0.0
    ST["confirm_msg"] = "SESSION RESET"
    ST["msg_t"]       = time.time()

def fmt_t(t):
    m = int(t // 60)
    s = t % 60
    return f"{m}:{s:05.2f}"

# ─── PDF Export ───────────────────────────────────────────────────────────────
def export_pdf():
    """Generate a professional session-summary PDF."""
    if not REPORTLAB_OK:
        ST["export_status"]   = "ERROR: Install reportlab  (pip install reportlab)"
        ST["export_status_t"] = time.time()
        return

    # Compute derived numbers
    elapsed = 0.0
    if ST["session_t0"]:
        elapsed = time.time() - ST["session_t0"]
    elapsed_str = f"{int(elapsed//3600)}h {int((elapsed%3600)//60)}m {int(elapsed%60)}s"

    avg_spd_mph = ST["avg_spd"]
    max_spd_mph = ST["max_spd"] * 0.621371
    trip_mi     = ST["trip_miles"]
    trip_km     = trip_mi * 1.60934
    eff         = ST["total_wh"] / trip_mi if trip_mi > 0.001 else 0.0
    warn_mins   = ST["speed_warn_total_secs"] / 60.0
    best_lap    = fmt_t(ST["lap_best"]) if ST["lap_best"] else "N/A"

    # Lap table rows
    lap_rows = [["Lap #", "Time", "vs Best"]]
    for i, lt in enumerate(ST["laps"], 1):
        diff = lt - ST["lap_best"] if ST["lap_best"] else 0.0
        diff_str = f"+{diff:.2f}s" if diff > 0.001 else "BEST"
        lap_rows.append([str(i), fmt_t(lt), diff_str])

    # File path
    fname  = f"kart_session_{datetime.now().strftime('%Y%m%d_%H%M%S')}.pdf"
    fpath  = os.path.join(LOG_DIR, fname)

    doc    = SimpleDocTemplate(
        fpath,
        pagesize=letter,
        leftMargin=0.75*inch,
        rightMargin=0.75*inch,
        topMargin=0.75*inch,
        bottomMargin=0.75*inch,
    )

    styles = getSampleStyleSheet()

    # Custom styles
    title_style = ParagraphStyle(
        "KartTitle",
        parent=styles["Title"],
        fontSize=26,
        textColor=colors.HexColor("#00D2FF"),
        spaceAfter=4,
        alignment=TA_CENTER,
    )
    subtitle_style = ParagraphStyle(
        "KartSub",
        parent=styles["Normal"],
        fontSize=11,
        textColor=colors.HexColor("#B0B0C8"),
        spaceAfter=2,
        alignment=TA_CENTER,
    )
    section_style = ParagraphStyle(
        "KartSection",
        parent=styles["Heading2"],
        fontSize=13,
        textColor=colors.HexColor("#FFD700"),
        spaceBefore=14,
        spaceAfter=6,
    )
    footer_style = ParagraphStyle(
        "KartFooter",
        parent=styles["Normal"],
        fontSize=8,
        textColor=colors.HexColor("#606080"),
        alignment=TA_CENTER,
    )

    # Styles for table cells to ensure they aren't black-on-black
    label_style = ParagraphStyle(
        "StatLabel",
        parent=styles["Normal"],
        fontSize=10,
        textColor=colors.HexColor("#9090B0"),
    )
    value_style = ParagraphStyle(
        "StatValue",
        parent=styles["Normal"],
        fontSize=10,
        textColor=colors.HexColor("#E8E8F0"),
        fontName="Helvetica-Bold",
    )
    lap_header_style = ParagraphStyle(
        "LapHeader",
        parent=styles["Normal"],
        fontSize=10,
        textColor=colors.HexColor("#00D2FF"),
        fontName="Helvetica-Bold",
        alignment=TA_CENTER,
    )
    lap_cell_style = ParagraphStyle(
        "LapCell",
        parent=styles["Normal"],
        fontSize=10,
        textColor=colors.HexColor("#D0D0E0"),
        alignment=TA_CENTER,
    )

    def make_stat_table(rows):
        """rows = [(label, value), ...]"""
        data = [[Paragraph(f"<b>{l}</b>", label_style),
                 Paragraph(str(v), value_style)] for l, v in rows]
        t = Table(data, colWidths=[2.8*inch, 3.8*inch])
        t.setStyle(TableStyle([
            ("BACKGROUND", (0, 0), (-1, 0),  colors.HexColor("#0D0D1A")),
            ("ROWBACKGROUNDS", (0, 0), (-1, -1),
             [colors.HexColor("#0D0D1A"), colors.HexColor("#111122")]),
            ("VALIGN",     (0, 0), (-1, -1), "MIDDLE"),
            ("ROWPADDING", (0, 0), (-1, -1), 6),
            ("GRID",       (0, 0), (-1, -1), 0.4, colors.HexColor("#2A2A40")),
        ]))
        return t

    def make_lap_table(rows):
        data = []
        for i, row in enumerate(rows):
            s = lap_header_style if i == 0 else lap_cell_style
            style_row = [Paragraph(str(c), s) for c in row]
            data.append(style_row)
        t = Table(data, colWidths=[1.2*inch, 2.0*inch, 2.0*inch])
        ts = TableStyle([
            ("BACKGROUND",  (0, 0), (-1, 0),  colors.HexColor("#1A1A30")),
            ("ROWBACKGROUNDS", (0, 1), (-1, -1),
             [colors.HexColor("#0D0D1A"), colors.HexColor("#111122")]),
            ("GRID",        (0, 0), (-1, -1), 0.4, colors.HexColor("#2A2A40")),
            ("ROWPADDING",  (0, 0), (-1, -1), 6),
            ("VALIGN",      (0, 0), (-1, -1), "MIDDLE"),
        ])
        # Highlight best lap green (using inline XML for paragraph)
        for i, row in enumerate(rows[1:], 1):
            if len(row) > 2 and row[2] == "BEST":
                # We update the data for that cell to have green text
                data[i][2] = Paragraph(f"<font color='#39FF14'><b>BEST</b></font>", lap_cell_style)
        t.setStyle(ts)
        return t

    # ── Build story ───────────────────────────────────────────────────────
    story = []

    story.append(Paragraph("COSMOS BUILDERS", title_style))
    story.append(Paragraph("Kart Dashboard v16  —  Session Report", subtitle_style))
    story.append(Paragraph("Team F2405  |  Hamtramck HS  |  Square One IVD", subtitle_style))
    story.append(Spacer(1, 0.15*inch))
    story.append(HRFlowable(width="100%", thickness=1,
                             color=colors.HexColor("#00D2FF"), spaceAfter=10))

    # ── Session overview ──────────────────────────────────────────────────
    story.append(Paragraph("SESSION OVERVIEW", section_style))
    story.append(make_stat_table([
        ("Session Started",        ST["session_start_str"] or "N/A"),
        ("Export Generated",       datetime.now().strftime("%Y-%m-%d  %H:%M:%S")),
        ("Total Session Duration", elapsed_str),
        ("Laps Completed",         str(ST["lap_n"])),
        ("Best Lap Time",          best_lap),
        ("Data Log File",          os.path.basename(ST["log_file"]) if ST["log_file"] else "None"),
    ]))

    # ── Performance ───────────────────────────────────────────────────────
    story.append(Paragraph("PERFORMANCE", section_style))
    story.append(make_stat_table([
        ("Top Speed",              f"{max_spd_mph:.1f} mph  /  {max_spd_mph*1.60934:.1f} km/h"),
        ("Average Speed",          f"{avg_spd_mph:.1f} mph  /  {avg_spd_mph*1.60934:.1f} km/h"),
        ("Total Distance",         f"{trip_mi:.4f} mi  /  {trip_km:.4f} km"),
        ("Peak Lateral G",         f"{ST['gl_peak']:+.3f} G"),
        ("Peak Longitudinal G",    f"{ST['gn_peak']:+.3f} G"),
        ("Max Lateral G (abs)",    f"{ST['gl_max']:.3f} G"),
        ("Max Longitudinal G (abs)",f"{ST['gn_max']:.3f} G"),
    ]))

    # ── Energy ────────────────────────────────────────────────────────────
    story.append(Paragraph("ENERGY & BATTERY", section_style))
    story.append(make_stat_table([
        ("Total Energy Used",      f"{ST['total_wh']:.2f} Wh"),
        ("Efficiency",             f"{eff:.1f} Wh/mi" if trip_mi > 0.001 else "N/A"),
        ("Battery at Export",      f"{ST['bpct']}%"),
        ("Voltage at Export",      f"{ST['bv']:.2f} V"),
        ("Battery Temp",           f"{ST['tb']:.1f} °C"),
        ("Motor Temp",             f"{ST['tm']:.1f} °C"),
    ]))

    # ── Safety events ─────────────────────────────────────────────────────
    story.append(Paragraph("SAFETY EVENTS", section_style))
    warn_pct = (ST["speed_warn_total_secs"] / elapsed * 100) if elapsed > 0 else 0.0
    story.append(make_stat_table([
        ("Speed Limit Set",        f"{ST['speed_limit']:.0f} mph"),
        ("Pit Lane Mode Used",     "YES" if ST["pit_lane"] else "NO"),
        ("Over-Limit Events",      str(ST["speed_warn_count"])),
        ("Time Over Limit",        f"{warn_mins:.1f} min  ({warn_pct:.1f}% of session)"),
        ("Low Battery Warnings",   "YES" if ST["bpct"] < 20 else "NO"),
        ("Overheat Events",        "YES" if ST["hot"] else "NO"),
    ]))

    # ── Lap breakdown ─────────────────────────────────────────────────────
    if len(ST["laps"]) > 0:
        story.append(Paragraph("LAP BREAKDOWN", section_style))
        story.append(make_lap_table(lap_rows))

    # ── Footer ────────────────────────────────────────────────────────────
    story.append(Spacer(1, 0.25*inch))
    story.append(HRFlowable(width="100%", thickness=0.5,
                             color=colors.HexColor("#2A2A40"), spaceAfter=6))
    story.append(Paragraph(
        f"Generated by Cosmos Builders Kart Dashboard v15  "
        f"•  {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}  "
        f"•  Hamtramck HHS  •  Team F2405",
        footer_style,
    ))

    try:
        doc.build(story)
        ST["export_status"]   = f"✔ Saved:  {fpath}"
        ST["export_status_t"] = time.time()
    except Exception as exc:
        ST["export_status"]   = f"Export ERROR: {exc}"
        ST["export_status_t"] = time.time()

# ─── Drawing helpers ──────────────────────────────────────────────────────────
def T(surf, text, font, color, x, y, anchor="center"):
    img = font.render(str(text), True, color)
    r   = img.get_rect()
    setattr(r, anchor, (x, y))
    surf.blit(img, r)

def arc_gauge(surf, cx, cy, R, frac, base_col, hi_col,
              thick=8, start_deg=220, span_deg=280):
    start = math.radians(start_deg)
    span  = math.radians(span_deg)
    end   = math.radians(start_deg + span_deg)
    rect  = pygame.Rect(cx - R, cy - R, R * 2, R * 2)
    pygame.draw.arc(surf, GY3, rect, start, end, thick + 2)
    if frac > 0.01:
        c = lerp_c(base_col, hi_col, frac)
        pygame.draw.arc(surf, c, rect, start, start + span * frac, thick)
        tip_a = start + span * frac
        tx = int(cx + R * math.cos(tip_a))
        ty = int(cy - R * math.sin(tip_a))
        glow(surf, tx, ty, thick + 4, c, 80)

def dist_c(d):
    if d < 30:  return RED
    if d < 80:  return (220, 130, 0)
    if d < 160: return GOLD
    return GRN

def batt_c(p):
    if p < 20: return RED
    if p < 40: return AMBER
    return GRN

def temp_c(t):
    if t > 60: return RED
    if t > 50: return AMBER
    return TEAL

# ─── Screen draw functions ────────────────────────────────────────────────────
def draw_header(surf, fonts, tab):
    fh = fonts["sm"]
    # Header background with subtle gradient
    for i in range(32):
        c = lerp_c((15, 15, 25), (8, 8, 14), i / 32)
        pygame.draw.line(surf, c, (0, i), (W, i))
    
    tabs = ["DRIVE", "TELEMETRY", "G-FORCE", "SETTINGS"]
    tw   = W // len(tabs)
    for i, lbl in enumerate(tabs):
        active = i == tab
        if active:
            # Active tab highlight
            pygame.draw.rect(surf, (30, 30, 50), (i * tw, 0, tw, 32))
            pygame.draw.line(surf, CYAN, (i * tw, 31), (i * tw + tw, 31), 2)
            # Subtle glow for active tab
            glow(surf, i * tw + tw // 2, 16, 25, CYAN, 40)
        
        col_tx = CYAN if active else GY2
        T(surf, lbl, fh, col_tx, i * tw + tw // 2, 16)
    pygame.draw.line(surf, BORDER, (0, 32), (W, 32), 1)

def draw_status(surf, fonts):
    fh = fonts["xs"]
    # Status bar background with subtle gradient
    for i in range(20):
        c = lerp_c((8, 8, 14), (12, 12, 20), i / 20)
