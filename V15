    for i, (key, desc) in enumerate(controls):
        kx = 20 + i * cw2 + cw2 // 2
        T(surf, key,  fonts["sm"], CYAN, kx, 396)
        T(surf, desc, fonts["xs"], GY2,  kx, 414)

# ─── Startup animation ────────────────────────────────────────────────────────
def run_startup(screen, fonts):
    clock  = pygame.time.Clock()
    t0     = time.time()
    TOTAL  = 5.8
    CX     = W // 2
    CY     = H // 2 - 20
    R      = 68
    START_A = math.radians(32)
    END_A   = math.radians(328)
    BRAND   = "COSMOS BUILDERS"
    f_brand = pygame.font.SysFont("dejavusans", 22, bold=True)
    f_tag   = pygame.font.SysFont("dejavusans", 11)

    def glow_circle(surf, cx, cy, rr, col, alpha):
        gs = pygame.Surface((rr * 2 + 2, rr * 2 + 2), pygame.SRCALPHA)
        pygame.draw.circle(gs, (*col, alpha), (rr + 1, rr + 1), rr)
        surf.blit(gs, (cx - rr - 1, cy - rr - 1))

    def draw_C(surf, progress, brightness=1.0):
        total   = END_A - START_A
        draw_to = START_A + total * min(progress, 1.0)
        rect    = pygame.Rect(CX - R, CY - R, R * 2, R * 2)
        for thick, am in [(20, 0.03), (14, 0.09), (8, 0.25), (4, 0.55), (2, 1.00)]:
            c  = lerp_c(GY2, WHT, am * brightness)
            a1 = -draw_to; a2 = -START_A
            if abs(a2 - a1) > 0.02:
                pygame.draw.arc(surf, c, rect, a1, a2, thick)
        if 0.01 < progress < 1.02:
            dx = int(CX + R * math.cos(-draw_to))
            dy = int(CY + R * math.sin(-draw_to))
            for rr, aa in [(18, 15), (12, 45), (7, 100), (4, 210)]:
                glow_circle(surf, dx, dy, rr, WHT, aa)

    def draw_brand(surf, progress):
        n_chars       = len(BRAND)
        chars_to_show = min(n_chars, int(progress * (n_chars + 2)))
        displayed     = BRAND[:chars_to_show]
        full_w        = f_brand.size(BRAND)[0]
        x_start       = CX - full_w // 2
        x             = x_start
        for i, ch in enumerate(displayed):
            char_age = progress * (n_chars + 2) - i
            alpha    = min(255, int(char_age * 180))
            ci       = f_brand.render(ch, True, WHT)
            ci.set_alpha(alpha)
            surf.blit(ci, (x, CY + R + 18))
            x += f_brand.size(ch)[0]

    while True:
        for ev in pygame.event.get():
            if ev.type == pygame.QUIT:
                pygame.quit(); sys.exit()
            if ev.type == pygame.KEYDOWN:
                return
        t = time.time() - t0
        if t > TOTAL: return
        draw_background(screen)
        if t < 1.6:
            p    = t / 1.6; ease = p * p * (3 - 2 * p)
            draw_C(screen, ease)
        elif t < 3.2:
            pulse = 0.85 + 0.15 * math.sin(t * 7)
            draw_C(screen, 1.0, pulse)
            draw_brand(screen, (t - 1.6) / 1.6)
        elif t < 4.6:
            sub = (t - 3.2) / 1.4
            draw_C(screen, 1.0, 0.9)
            draw_brand(screen, 1.0)
            fa = min(255, int(sub * 255))
            ti = f_tag.render("KART DASHBOARD", True, GY2)
            ti.set_alpha(fa)
            screen.blit(ti, ti.get_rect(center=(CX, CY + R + 48)))
        else:
            fade_t = (t - 4.6) / 1.2
            draw_C(screen, 1.0, 1.0 - fade_t)
            draw_brand(screen, 1.0)
            fade = pygame.Surface((W, H))
            fade.fill(BG)
            fade.set_alpha(int(fade_t * 255))
            screen.blit(fade, (0, 0))
        pygame.display.flip()
        clock.tick(60)

# ─── Main loop ────────────────────────────────────────────────────────────────
SH_BTN = 36

def main():
    pygame.init()
    screen = pygame.display.set_mode((W, H))
    pygame.display.set_caption("Cosmos Builders — Kart Dashboard v16")
    fonts = {
        "big":  pygame.font.SysFont("dejavusans", 52, bold=True),
        "head": pygame.font.SysFont("dejavusans", 18, bold=True),
        "med":  pygame.font.SysFont("dejavusans", 14, bold=True),
        "sm":   pygame.font.SysFont("dejavusans", 11),
        "xs":   pygame.font.SysFont("dejavusans",  9),
    }
    run_startup(screen, fonts)
    clock = pygame.time.Clock()

    START_BTN = (4, H - 20 - SH_BTN,          192, SH_BTN)
    RESET_BTN = (4, H - 20 - SH_BTN * 2 - 6,  192, SH_BTN)

    while True:
        # Reset-arm timeout
        if ST["reset_armed"] and time.time() - ST["reset_arm_t"] > 8:
            ST["reset_armed"]  = False
            ST["confirm_msg"]  = "Reset cancelled"
            ST["msg_t"]        = time.time()

        for ev in pygame.event.get():
            if ev.type == pygame.QUIT:
                pygame.quit(); sys.exit()

            if ev.type == pygame.KEYDOWN:
                k = ev.key
                if   k == pygame.K_ESCAPE: pygame.quit(); sys.exit()
                elif k == pygame.K_TAB:    ST["tab"] = (ST["tab"] + 1) % 4
                elif k == pygame.K_SPACE:  toggle_start()
                elif k == pygame.K_l:      toggle_lap()
                elif k == pygame.K_n:      ST["night"] = not ST["night"]
                elif k == pygame.K_e:      export_pdf()          # ← NEW
                elif k == pygame.K_p:
                    ST["pit_lane"] = not ST["pit_lane"]
                    ST["confirm_msg"] = ("PIT LANE MODE ON"
                                        if ST["pit_lane"] else "PIT LANE MODE OFF")
                    ST["msg_t"] = time.time()
                elif k == pygame.K_r:
                    if ST["reset_armed"]:
                        do_reset()
                    else:
                        ST["reset_armed"]  = True
                        ST["reset_arm_t"]  = time.time()
                        ST["confirm_msg"]  = "⚠ Press R again to confirm RESET!"
                        ST["msg_t"]        = time.time()
                elif k == pygame.K_1: ST["tab"] = 0
                elif k == pygame.K_2: ST["tab"] = 1
                elif k == pygame.K_3: ST["tab"] = 2
                elif k == pygame.K_4: ST["tab"] = 3
                elif k == pygame.K_UP and ST["tab"] == 3:
                    ST["speed_limit"] = min(80, ST["speed_limit"] + 5)
                elif k == pygame.K_DOWN and ST["tab"] == 3:
                    ST["speed_limit"] = max(5,  ST["speed_limit"] - 5)

            if ev.type == pygame.MOUSEBUTTONDOWN and ev.button == 1:
                mx, my = ev.pos
                # Tab bar click
                if my < 32:
                    ST["tab"] = min(mx // (W // 4), 3)
                # Start button
                sx, sy, sw, sh = START_BTN
                if sx <= mx <= sx + sw and sy <= my <= sy + sh:
                    toggle_start()
                # Reset button
                rx2, ry2, rw2, rh2 = RESET_BTN
                if rx2 <= mx <= rx2 + rw2 and ry2 <= my <= ry2 + rh2:
                    if ST["reset_armed"]:
                        do_reset()
                    else:
                        ST["reset_armed"]  = True
                        ST["reset_arm_t"]  = time.time()
                        ST["confirm_msg"]  = "Click RESET again to confirm!"
                        ST["msg_t"]        = time.time()
                # Export button click (settings tab)
                if ST["tab"] == 3:
                    EX = 400; EY = 172; EW = 380
                    BW, BH = 240, 38
                    BX = EX + (EW - BW) // 2
                    BY = EY + 36
                    if BX <= mx <= BX + BW and BY <= my <= BY + BH:
                        export_pdf()

        demo_tick()
        draw_background(screen)
        tab = ST["tab"]
        draw_header(screen, fonts, tab)
        if   tab == 0: screen_drive(screen, fonts, START_BTN, RESET_BTN)
        elif tab == 1: screen_telemetry(screen, fonts)
        elif tab == 2: screen_gforce(screen, fonts)
        elif tab == 3: screen_settings(screen, fonts, START_BTN, RESET_BTN)
        draw_status(screen, fonts)
        pygame.display.flip()
        clock.tick(FPS)

if __name__ == "__main__":
    main()
