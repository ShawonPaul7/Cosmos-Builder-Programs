# ─── Color palette ────────────────────────────────────────────────────────────
BG      = (3,   3,   7)
BG2     = (8,   8,  14)
PANEL   = (18,  18,  28)
BORDER  = (45,  45,  65)
AMBER   = (255, 140,  0)
AMBER2  = (200, 100,  0)
CYAN    = (0,   210, 255)
RED     = (190,  10,  20)
RED2    = (150,  20,  28)
GRN     = (57,  255,  20)
GRN2    = (30,  160,  10)
WHT     = (240, 240, 250)
GY1     = (180, 180, 195)
GY2     = (100, 100, 120)
GY3     = (45,   45,  65)
GOLD    = (255, 200,  50)
PRP     = (140,  80, 255)
TEAL    = (0,   180, 150)
OFF     = (25,   25,  38)
BLU     = (75,  155, 255)   # ← fixed: defined at module level now

def lerp_c(a, b, t):
    return tuple(int(a[i] + (b[i] - a[i]) * t) for i in range(3))

def dim(c, f=0.45):
    return tuple(int(v * f) for v in c)

def glow(surf, cx, cy, r, color, alpha=60):
    s = pygame.Surface((r * 2, r * 2), pygame.SRCALPHA)
    pygame.draw.circle(s, (*color, alpha), (r, r), r)
    surf.blit(s, (cx - r, cy - r))

def draw_panel(surf, x, y, w, h):
    """Draws a smooth, premium panel with rounded corners and subtle depth."""
    # Main panel with slightly rounded corners
    pygame.draw.rect(surf, PANEL, (x, y, w, h), border_radius=12)

    # Glass-like highlight surface
    overlay = pygame.Surface((w, h), pygame.SRCALPHA)
    # Subtle top-down gradient highlight
    for i in range(h // 2):
        a = int(12 * (1 - i / (h // 2)))
        pygame.draw.line(overlay, (255, 255, 255, a), (1, i), (w - 2, i))

    # Inner border for a "beveled" or "inset" feel
    pygame.draw.rect(overlay, (255, 255, 255, 6), (1, 1, w - 2, h - 2), 1, border_radius=11)
    surf.blit(overlay, (x, y))

    # Outer border (the main edge)
    pygame.draw.rect(surf, BORDER, (x, y, w, h), 1, border_radius=12)

def draw_background(surf):
    """Fills the screen with a subtle vertical gradient for a smoother look."""
    for i in range(H):
        c = lerp_c(BG, BG2, i / H)
        pygame.draw.line(surf, c, (0, i), (W, i))

