def _draw_speed_warning(surf, fonts, now):
    """
    Full-screen OVER SPEED LIMIT warning — clean, clear, impossible to miss.
    Shows a bold red sign with the current speed and the active limit.
    """
    limit = 5.0 if ST["pit_lane"] else ST["speed_limit"]
    pulse = (math.sin(now * 4) + 1) / 2          # 0 → 1, slow pulse

    # ── Semi-transparent red vignette ────────────────────────────────────
    ov = pygame.Surface((W, H), pygame.SRCALPHA)
    border_alpha = int(120 + 80 * pulse)
    pygame.draw.rect(ov, (180, 0, 10, border_alpha), (0, 0, W, H), 18)
    surf.blit(ov, (0, 0))

    # ── Warning sign panel ───────────────────────────────────────────────
    PW, PH = 480, 190
    PX, PY = (W - PW) // 2, (H - PH) // 2 - 10

    # Panel glow
    glow(surf, W // 2, H // 2 - 10, 180, RED, int(30 + 20 * pulse))

    # Panel background
    panel_surf = pygame.Surface((PW, PH), pygame.SRCALPHA)
    panel_surf.fill((25, 0, 0, 210))
    surf.blit(panel_surf, (PX, PY))

    # Red border (pulse thickness)
    border_thick = 3 + int(pulse * 2)
    pygame.draw.rect(surf, RED, (PX, PY, PW, PH), border_thick, border_radius=14)

    # Bright inner border accent
    pygame.draw.rect(surf, (255, 60, 60), (PX + 4, PY + 4, PW - 8, PH - 8),
                     1, border_radius=10)

    # ── Icon + main text ─────────────────────────────────────────────────
    f_icon = pygame.font.SysFont("dejavusans", 36, bold=True)
    f_main = pygame.font.SysFont("dejavusans", 42, bold=True)
    f_sub  = pygame.font.SysFont("dejavusans", 20, bold=True)
    f_spd  = pygame.font.SysFont("dejavusans", 32, bold=True)

    CX = W // 2
    CY = PY + PH // 2

    # Warning triangle icon
    icon_col = lerp_c(RED, GOLD, pulse)
    T(surf, "⚠", f_icon, icon_col, CX, PY + 26)

    # "OVER THE SPEED LIMIT" — the required label
    T(surf, "OVER THE SPEED LIMIT", f_main, WHT, CX, CY - 10)

    # Speed readout line
    spd_col = lerp_c(WHT, RED, pulse)
    T(surf,
      f"{ST['spd_mph']:.0f} MPH  —  LIMIT: {limit:.0f} MPH",
      f_spd, spd_col, CX, CY + 38)

    # Subtle "SLOW DOWN" reminder at bottom of panel
    T(surf, "REDUCE SPEED IMMEDIATELY", f_sub, AMBER, CX, PY + PH - 18)

