def draw_speed_gauge(surf, cx, cy, R, spd_mph, fonts):
    MAX  = 80
    frac = min(spd_mph, MAX) / MAX
    col_arc = lerp_c(CYAN, RED, frac)
    glow(surf, cx, cy, R + 14, col_arc, 25)
    arc_gauge(surf, cx, cy, R, frac, CYAN, RED, thick=10)
    for s in range(0, MAX + 1, 10):
        a  = math.radians(220 + 280 * s / MAX)
        ri = R - 16; ro = R - 6
        xi = int(cx + ri * math.cos(a)); yi = int(cy - ri * math.sin(a))
        xo = int(cx + ro * math.cos(a)); yo = int(cy - ro * math.sin(a))
        pygame.draw.line(surf, GY2, (xi, yi), (xo, yo), 2 if s % 20 == 0 else 1)
        if s % 20 == 0:
            xt = int(cx + (R - 26) * math.cos(a))
            yt = int(cy - (R - 26) * math.sin(a))
            T(surf, str(s), fonts["xs"], GY1, xt, yt)
    T(surf, f"{int(spd_mph)}", fonts["big"], WHT, cx, cy)
    T(surf, "MPH", fonts["xs"], CYAN, cx, cy + 34)
    T(surf, f"{int(spd_mph * 1.609)} km/h", fonts["xs"], GY2, cx, cy + 46)

def draw_graph(surf, x, y, w, h, hist, label, col):
    draw_panel(surf, x, y, w, h)
    pts = list(hist)
    for i in range(1, 4):
        gy = y + (h * i // 4)
        pygame.draw.line(surf, (25, 25, 35), (x + 10, gy), (x + w - 10, gy), 1)

    MX = 1  # safe default
    if len(pts) > 1:
        MX = max(max(pts), 1)
        coords = [
            (x + 10 + i * (w - 20) / (len(pts) - 1),
             y + h - 10 - (v / MX) * (h - 20))
            for i, v in enumerate(pts)
        ]
        fill_pts = (
            [(coords[-1][0], y + h - 10)]
            + list(reversed(coords))
            + [(coords[0][0], y + h - 10)]
        )
        s = pygame.Surface((w, h), pygame.SRCALPHA)
        pygame.draw.polygon(s, (*col, 30),
                            [(p[0] - x, p[1] - y) for p in fill_pts])
        surf.blit(s, (x, y))
        pygame.draw.lines(surf, col, False, coords, 2)
        pygame.draw.circle(surf, col,
                           (int(coords[-1][0]), int(coords[-1][1])), 3)
        glow(surf, int(coords[-1][0]), int(coords[-1][1]), 6, col, 80)

    T(surf, label,
      pygame.font.SysFont("dejavusans", 10, bold=True), GY2,
      x + 10, y + 10, "midleft")
    if pts:
        T(surf, f"{pts[-1]:.1f}",
          pygame.font.SysFont("dejavusans", 14, bold=True), WHT,
          x + w - 10, y + 15, "midright")
        T(surf, f"MAX: {MX:.1f}",
          pygame.font.SysFont("dejavusans", 8), GY3,
          x + 10, y + h - 8, "midleft")

